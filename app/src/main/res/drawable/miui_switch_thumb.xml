<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- 极淡阴影层 -->
    <item android:top="2dp" android:left="1dp" android:right="1dp">
        <shape android:shape="oval">
            <solid android:color="#1A000000" />
            <size android:width="26dp" android:height="26dp" />
        </shape>
    </item>
    <!-- 主体 -->
    <item android:bottom="2dp" android:left="1dp" android:right="1dp">
        <shape android:shape="oval">
            <solid android:color="#FFFFFF" />
            <size android:width="26dp" android:height="26dp" />
            <stroke android:width="0.5dp" android:color="#1A000000" />
        </shape>
    </item>
</layer-list>
