<?xml version="1.0" encoding="utf-8"?>
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="24dp"
    android:height="24dp"
    android:viewportWidth="24"
    android:viewportHeight="24">

    <!-- 手机主体：45度倾斜，尺寸约 5x9，线条粗 2.2dp -->
    <path
        android:strokeColor="#FFFFFF"
        android:strokeWidth="2.2"
        android:strokeLineCap="round"
        android:strokeLineJoin="round"
        android:fillColor="#00000000"
        android:pathData="M 12,12 m -2.5,-4.5 l 5,0 a 1,1 0 0,1 1,1 l 0,7 a 1,1 0 0,1 -1,1 l -5,0 a 1,1 0 0,1 -1,-1 l 0,-7 a 1,1 0 0,1 1,-1"
        android:pivotX="12"
        android:pivotY="12"
        android:rotation="45" />

    <!-- 右上角旋转弧线：半径 9.0，确保不超出边界 -->
    <path
        android:strokeColor="#FFFFFF"
        android:strokeWidth="2.2"
        android:strokeLineCap="round"
        android:fillColor="#00000000"
        android:pathData="M 21,12 A 9,9 0 0,0 12,3" />
    <!-- 右上角箭头：尖端指向左侧 -->
    <path
        android:fillColor="#FFFFFF"
        android:pathData="M 12,1 L 12,5 L 8.5,3 Z" />

    <!-- 左下角旋转弧线：半径 9.0，完全对称 -->
    <path
        android:strokeColor="#FFFFFF"
        android:strokeWidth="2.2"
        android:strokeLineCap="round"
        android:fillColor="#00000000"
        android:pathData="M 3,12 A 9,9 0 0,0 12,21" />
    <!-- 左下角箭头：尖端指向右侧 -->
    <path
        android:fillColor="#FFFFFF"
        android:pathData="M 12,23 L 12,19 L 15.5,21 Z" />

</vector>
