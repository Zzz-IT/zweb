<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/bottomBar"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical">

    <!-- 进度条 (物理吸附在搜索栏最顶端) -->
    <ProgressBar
        android:id="@+id/progressBar"
        style="?android:attr/progressBarStyleHorizontal"
        android:layout_width="match_parent"
        android:layout_height="2dp"
        android:max="100"
        android:progressTint="#007AFF"
        android:visibility="gone" />

    <LinearLayout
        android:id="@+id/bottomBarContent"
        android:layout_width="match_parent"
        android:layout_height="72dp"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingLeft="12dp"
        android:paddingRight="12dp">

    <LinearLayout
        android:id="@+id/addressTouchArea"
        android:layout_width="0dp"
        android:layout_height="48dp"
        android:layout_weight="1"
        android:layout_marginRight="8dp"
        android:background="@drawable/bg_search_bar"
        android:gravity="center_vertical"
        android:paddingLeft="16dp"
        android:paddingRight="4dp">

        <EditText
            android:id="@+id/urlInput"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:background="@android:color/transparent"
            android:hint="搜索或输入网址"
            android:textColorHint="#999999"
            android:singleLine="true"
            android:textSize="15sp" />

        <ImageButton
            android:id="@+id/btnGo"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="?android:attr/selectableItemBackgroundBorderless"
            android:src="@drawable/ic_go"
            android:scaleType="centerInside" />
    </LinearLayout>

    <ImageButton
        android:id="@+id/btnHome"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:background="?android:attr/selectableItemBackgroundBorderless"
        android:src="@drawable/ic_home"
        android:scaleType="centerInside" />

    <ImageButton
        android:id="@+id/btnTabs"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:background="?android:attr/selectableItemBackgroundBorderless"
        android:src="@drawable/ic_tabs"
        android:scaleType="centerInside" />

    <ImageButton
        android:id="@+id/btnTool"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:background="?android:attr/selectableItemBackgroundBorderless"
        android:src="@drawable/ic_tool"
        android:scaleType="centerInside" />
    </LinearLayout>
</LinearLayout>
