<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/rootContainer"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFFFFF">

    <!-- 网页层 -->
    <WebView
        android:id="@+id/webView"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:visibility="gone" />

    <!-- 首页层 -->
    <include layout="@layout/preview_home" />

    <!-- 底部导航栏 -->
    <include
        layout="@layout/preview_bottom_bar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom" />

    <!-- 悬浮播放控制 (位于底栏上方) -->
    <include
        layout="@layout/preview_floating_player"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:layout_marginBottom="68dp" />

    <!-- 进度条 (紧贴底栏上方) -->
    <ProgressBar
        android:id="@+id/progressBar"
        style="?android:attr/progressBarStyleHorizontal"
        android:layout_width="match_parent"
        android:layout_height="2dp"
        android:layout_gravity="bottom"
        android:layout_marginBottom="72dp"
        android:max="100"
        android:progressTint="#007AFF"
        android:visibility="gone" />

    <!-- 全屏容器 (最顶层) -->
    <FrameLayout
        android:id="@+id/fullscreenContainer"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#000000"
        android:visibility="gone" />

    <!-- 全屏控制层 -->
    <include layout="@layout/preview_fullscreen_player" />

</FrameLayout>
