<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/rootContainer"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFFFFF">

    <!-- 网页多标签容器层 -->
    <FrameLayout
        android:id="@+id/webViewContainer"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:visibility="gone" />

    <!-- 悬浮手势层 (拦截 WebView 的视频区域触摸) -->
    <View
        android:id="@+id/floatingGestureLayer"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_marginBottom="140dp"
        android:background="@android:color/transparent"
        android:clickable="true"
        android:focusable="true"
        android:visibility="gone" />

    <!-- 首页层 -->
    <include layout="@layout/preview_home" />

    <!-- 底部导航栏 -->
    <include
        layout="@layout/preview_bottom_bar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom" />

    <!-- 悬浮播放控制 (位于底栏上方) -->
    <include
        layout="@layout/preview_floating_player"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:layout_marginBottom="68dp" />


    <!-- 全屏容器 (最顶层) -->
    <FrameLayout
        android:id="@+id/fullscreenContainer"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#000000"
        android:visibility="gone" />

    <!-- 全屏手势层 (拦截全屏区域触摸) -->
    <View
        android:id="@+id/fullscreenGestureLayer"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@android:color/transparent"
        android:clickable="true"
        android:focusable="true"
        android:elevation="35dp"
        android:visibility="gone" />

    <!-- 全屏控制层 -->
    <include layout="@layout/preview_fullscreen_player" />

</FrameLayout>
