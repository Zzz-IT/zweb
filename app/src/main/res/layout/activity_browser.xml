<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/rootContainer"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFFFFF"
    android:clipChildren="false"
    android:clipToPadding="false">

    <!-- 网页多标签容器层 -->
    <FrameLayout
        android:id="@+id/webViewContainer"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:visibility="gone" />

    <!-- 顶部状态栏点击热区 -->
    <View
        android:id="@+id/statusBarClickArea"
        android:layout_width="match_parent"
        android:layout_height="40dp"
        android:background="@android:color/transparent"
        android:clickable="false"
        android:focusable="false" />

    <!-- 首页层 -->
    <include layout="@layout/preview_home" />

    <!-- 底部导航栏容器：修正布局方式，解决进入App时的空白及横滑背景露出问题 -->
    <com.zzz.webvideobrowser.GestureInterceptLayout
        android:id="@+id/bottomBarGestureHotArea"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:clipChildren="false"
        android:clipToPadding="false"
        android:clickable="true"
        android:focusable="false">

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="140dp"
            android:layout_gravity="bottom"
            android:clipChildren="false"
            android:clipToPadding="false">

            <!-- 底栏背景延展层：设为超宽以解决横滑露出背景问题 -->
            <View
                android:id="@+id/bottomBarDragUnderlay"
                android:layout_width="1000dp"
                android:layout_height="72dp"
                android:layout_gravity="bottom|center_horizontal"
                android:background="#F2F2F7"
                android:clickable="false"
                android:focusable="false" />

            <!-- 底部导航栏 -->
            <include
                layout="@layout/preview_bottom_bar"
                android:layout_width="match_parent"
                android:layout_height="72dp"
                android:layout_gravity="bottom" />
        </FrameLayout>

    </com.zzz.webvideobrowser.GestureInterceptLayout>

    <!-- 资源控制悬浮按钮 -->
    <ImageButton
        android:id="@+id/btnResourceHub"
        android:layout_width="56dp"
        android:layout_height="56dp"
        android:layout_gravity="bottom|end"
        android:layout_marginEnd="16dp"
        android:layout_marginBottom="92dp"
        android:background="@drawable/bg_fab_video"
        android:src="@drawable/ic_play"
        android:scaleType="centerInside"
        android:elevation="16dp"
        android:visibility="gone"
        android:contentDescription="可控视频" />

    <!-- 全屏容器 (最顶层) -->
    <FrameLayout
        android:id="@+id/fullscreenContainer"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#000000"
        android:visibility="gone" />

    <!-- 全屏手势层 -->
    <View
        android:id="@+id/fullscreenGestureLayer"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@android:color/transparent"
        android:clickable="true"
        android:focusable="true"
        android:elevation="35dp"
        android:visibility="gone" />

    <!-- 全屏控制层 -->
    <include layout="@layout/preview_fullscreen_player" />

</FrameLayout>
