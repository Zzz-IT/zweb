<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/floatingControls"
    android:layout_width="match_parent"
    android:layout_height="64dp"
    android:layout_margin="12dp"
    android:background="@drawable/bg_rounded_card"
    android:backgroundTint="#CC000000"
    android:gravity="center_vertical"
    android:orientation="horizontal"
    android:paddingLeft="12dp"
    android:paddingRight="12dp"
    android:elevation="4dp">

    <ImageButton
        android:id="@+id/btnFloatPlayPause"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:background="?android:attr/selectableItemBackgroundBorderless"
        android:src="@drawable/ic_play"
        android:scaleType="centerInside" />

    <RelativeLayout
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1">

        <SeekBar
            android:id="@+id/seekFloat"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_centerVertical="true"
            android:max="1000"
            android:progressTint="#FFFFFF"
            android:thumbTint="#FFFFFF" />

        <TextView
            android:id="@+id/txtFloatTime"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_below="@id/seekFloat"
            android:layout_marginTop="-4dp"
            android:text="00:00 / 00:00"
            android:textColor="#B3FFFFFF"
            android:textSize="10sp"
            android:gravity="center" />
    </RelativeLayout>

    <ImageButton
        android:id="@+id/btnFloatFull"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:background="?android:attr/selectableItemBackgroundBorderless"
        android:src="@drawable/ic_fullscreen"
        android:scaleType="centerInside" />
</LinearLayout>
